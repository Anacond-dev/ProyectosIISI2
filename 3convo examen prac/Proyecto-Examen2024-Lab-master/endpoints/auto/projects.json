{
    "getAll": {
        "description": "Gets all entries from 'projects'",
        "route": "/projects",
        "method": "GET",
        "sql": "SELECT * FROM projects",
        "auth_required": false,
        "allowed_roles": [
            "*"
        ]
    },
    "getById": {
        "description": "Gets an entry from 'projects' by its primary key",
        "route": "/projects/$projectId",
        "method": "GET",
        "sql": "SELECT * FROM projects WHERE projectId = $projectId",
        "auth_required": false,
        "allowed_roles": [
            "*"
        ]
    },
    "create": {
        "description": "Creates a new entry in 'projects'",
        "route": "/projects",
        "method": "POST",
        "sql": "INSERT INTO projects (userId, name, projectLeader, endDate, budget, description, imageUrl) VALUES ($userId, $name, $projectLeader, $endDate, $budget, $description, $imageUrl)",
        "request_body_params": [
            "userId",
            "name",
            "projectLeader",
            "endDate",
            "budget",
            "description",
            "imageUrl"
        ],
        "auth_required": true,
        "allowed_roles": [
            "*"
        ]
    },
    "update": {
        "description": "Updates an existing entry in 'projects' by its primary key",
        "route": "/projects/$projectId",
        "method": "PUT",
        "sql": "UPDATE projects SET userId = $userId, name = $name, projectLeader = $projectLeader, endDate = $endDate, budget = $budget, description = $description, imageUrl = $imageUrl WHERE projectId = $projectId",
        "request_body_params": [
            "userId",
            "name",
            "projectLeader",
            "endDate",
            "budget",
            "description",
            "imageUrl"
        ],
        "auth_required": true,
        "allowed_roles": [
            "*"
        ]
    },
    "delete": {
        "description": "Deletes an existing entry in 'projects' by its primary key",
        "route": "/projects/$projectId",
        "method": "DELETE",
